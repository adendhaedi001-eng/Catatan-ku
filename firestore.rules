rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Global Safety Net - Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. Individual User Settings match
    match /users/{userId} {
      // Users can only retrieve their own user document
      allow get: if request.auth != null && request.auth.uid == userId;
      
      // Users can write under their own ID if validated
      allow create, update: if request.auth != null && request.auth.uid == userId && isValidUser();
      
      // Deletions are forbidden by users
      allow delete: if false;
    }

    // Validation Blueprint
    function isValidUser() {
      let data = request.resource.data;
      return data.updatedAt is string 
        && data.updatedAt.size() <= 64
        && (!data.keys().hasAll(['finance']) || data.finance is map)
        && (!data.keys().hasAll(['iuran']) || data.iuran is map);
    }
  }
}
